# App
NODE_ENV=development
PORT=4000
APP_NAME=wellness-package-api

# Database
DATABASE_URL=postgresql://postgres:secret@localhost:5433/myapp_dev?schema=public

# JWT
JWT_SECRET=your-super-secret-key
JWT_REFRESH_SECRET=your-super-refresh-secret-key
JWT_ACCESS_EXPIRES_IN=3h
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
